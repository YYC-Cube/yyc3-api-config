# YYC³ 统一API网关 - 测试环境配置示例
# Environment: Staging
# Server: test-api.0379.world
# Domain: test-api.0379.world
#
# 注意：这是一个示例文件，请复制为 .env 并填入真实的API密钥
# Note: This is an example file. Copy to .env and fill in real API keys

# ============================================
# 应用配置 / Application Configuration
# ============================================
NODE_ENV=staging
APP_NAME=yyc3_aify
APP_PORT=3200
APP_HOST=0.0.0.0
APP_VERSION=2.0.0

# ============================================
# API配置 / API Configuration
# ============================================
API_BASE_URL=https://test-api.0379.world
API_HEALTH_CHECK=https://test-api.0379.world/health
API_WS_URL=wss://test-api.0379.world/ws

# ============================================
# Redis配置 / Redis Configuration
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=1
REDIS_MAX_RETRIES=3
REDIS_RETRY_DELAY=1000

# ============================================
# JWT配置 / JWT Configuration
# ============================================
JWT_SECRET=staging_jwt_secret_key_for_testing_only_not_secure
JWT_EXPIRES_IN=3d
JWT_ALGORITHM=HS256

# ============================================
# AI API Keys / AI API Keys
# ============================================
# Qwen API Key
QWEN_API_KEY=your_qwen_api_key_here
QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen2.5-72b-instruct

# Zhipu API Key
ZHIPU_API_KEY=your_zhipu_api_key_here
ZHIPU_API_BASE=https://open.bigmodel.cn/api/paas/v4
ZHIPU_MODEL=glm-4

# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4

# Ollama Configuration
OLLAMA_API_BASE=http://localhost:11434
OLLAMA_MODEL=llama2

# ============================================
# 日志配置 / Logging Configuration
# ============================================
LOG_LEVEL=info
LOG_FILE=./logs/aify-staging.log
LOG_MAX_SIZE=100m
LOG_MAX_FILES=10
LOG_DATE_PATTERN=YYYY-MM-DD

# ============================================
# 限流配置 / Rate Limiting Configuration
# ============================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=500
RATE_LIMIT_SKIP_FAILED_REQUESTS=true
RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=false

# ============================================
# 超时配置 / Timeout Configuration
# ============================================
REQUEST_TIMEOUT=60000
CONNECTION_TIMEOUT=10000
KEEP_ALIVE_TIMEOUT=60000
HEADERS_TIMEOUT=60000

# ============================================
# WebSocket配置 / WebSocket Configuration
# ============================================
WS_ENABLED=true
WS_HEARTBEAT_INTERVAL=30000
WS_MAX_CONNECTIONS=200
WS_MESSAGE_QUEUE_SIZE=200

# ============================================
# 设备管理配置 / Device Management Configuration
# ============================================
DEVICE_MANAGER_ENABLED=true
DEVICE_HEARTBEAT_INTERVAL=30000
DEVICE_OFFLINE_THRESHOLD=120000
DEVICE_RETRY_INTERVAL=5000
DEVICE_MAX_RETRIES=3

# ============================================
# 安全配置 / Security Configuration
# ============================================
CORS_ENABLED=true
CORS_ORIGIN=https://test-api.0379.world,https://test.0379.world
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
CORS_HEADERS=Content-Type,Authorization,X-Requested-With

HELMET_ENABLED=true
HELMET_CSP_ENABLED=true

# ============================================
# 监控配置 / Monitoring Configuration
# ============================================
PM2_MONITORING_ENABLED=true
PM2_MONITORING_PORT=9615
HEALTH_CHECK_INTERVAL=10000

# ============================================
# 备份配置 / Backup Configuration
# ============================================
BACKUP_ENABLED=true
BACKUP_INTERVAL=86400000
BACKUP_RETENTION_DAYS=7
BACKUP_PATH=./backups

# ============================================
# 邮件通知配置 / Email Notification Configuration
# ============================================
EMAIL_ENABLED=true
EMAIL_SMTP_HOST=smtp.0379.email
EMAIL_SMTP_PORT=587
EMAIL_SMTP_SECURE=false
EMAIL_SMTP_USER=admin@0379.email
EMAIL_SMTP_PASS=your_email_password
EMAIL_FROM=admin@0379.email

# ============================================
# 钉钉通知配置 / DingTalk Notification Configuration
# ============================================
DINGTALK_ENABLED=true
DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=your_token
DINGTALK_SECRET=your_secret

# ============================================
# 企业微信通知配置 / WeChat Work Notification Configuration
# ============================================
WECHAT_WORK_ENABLED=true
WECHAT_WORK_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your_key

# ============================================
# 其他配置 / Other Configuration
# ============================================
DEBUG=false
VERBOSE=false
ENABLE_SWAGGER=true
ENABLE_METRICS=true
ENABLE_TRACING=true
