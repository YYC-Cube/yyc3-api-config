# YYC³ API开发者配置包 - Git忽略文件
# Environment: Development/Staging
# Purpose: 保护敏感信息不被提交到版本控制

# ============================================
# 环境变量文件 / Environment Files
# ============================================
.env
.env.local
.env.*.local

# ============================================
# 日志文件 / Log Files
# ============================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ============================================
# 依赖目录 / Dependency Directories
# ============================================
node_modules/
jspm_packages/

# ============================================
# 构建输出 / Build Output
# ============================================
dist/
build/
out/
.next/
.nuxt/
.vuepress/dist/

# ============================================
# 测试覆盖率 / Test Coverage
# ============================================
coverage/
.nyc_output/

# ============================================
# IDE配置 / IDE Configuration
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ============================================
# 临时文件 / Temporary Files
# ============================================
tmp/
temp/
*.tmp
*.temp

# ============================================
# 备份文件 / Backup Files
# ============================================
*.bak
*.backup
backups/

# ============================================
# 操作系统文件 / OS Files
# ============================================
.DS_Store
Thumbs.db
desktop.ini

# ============================================
# 包管理器 / Package Managers
# ============================================
package-lock.json
yarn.lock
pnpm-lock.yaml

# ============================================
# 其他 / Others
# ============================================
.cache/
.parcel-cache/
